{
  "name": "starter-crud-auth-api-express",
  "version": "1.0.0",
  "engines": {
    "node": "14.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --ignore public/",
    "production": "NODE_ENV=production",
    "setup": "node ./setup/setup.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand --testTimeout=180000 --forceExit tests/integration",
    "test:performance": "artillery run performance/review-list.yml",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "connect-mongo": "^4.4.0",
    "dotenv": "4.0.0",
    "es6-promisify": "5.0.0",
    "express": "4.17.1",
    "express-session": "^1.17.1",
    "glob": "7.1.1",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.9.10",
    "mongoose-autopopulate": "^0.14.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "artillery": "^1.7.9",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^1.19.2",
    "prettier": "^3.8.1",
    "supertest": "^7.1.3"
  },
  "description": "Just you wait folks!",
